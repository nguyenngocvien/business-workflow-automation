{
  "name": "user-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "download:openapi": "node scripts/download-openapi.mjs",
    "gen:api": "orval --config orval.config.js",
    "gen:api:identity": "orval --config orval.config.js --project identity",
